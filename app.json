{
  "expo": {
    "name": "Nexus",
    "slug": "houseops",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/nexus-icon.png",
    "scheme": "nexus",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.houseops.nexus",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "We use the camera to scan barcodes for inventory.",
        "NSPhotoLibraryUsageDescription": "We need access to save exported CSV files to your device.",
        "NSPhotoLibraryAddUsageDescription": "We need access to save exported CSV files to your device."
      }
    },
    "android": {
      "package": "com.houseops.nexus",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/nexus-icon.png",
        "backgroundColor": "#0F172A",
        "monochromeImage": "./assets/images/nexus-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/nexus-splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A",
          "dark": {
            "backgroundColor": "#0F172A"
          }
        }
      ],
      "expo-camera",
      "expo-notifications",
      "expo-file-system"
    ],
    "experiments": {
      "newArchEnabled": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "98f68256-6eef-4add-b46a-42f4564a8cb7"
      }
    },
    "owner": "houseops",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/98f68256-6eef-4add-b46a-42f4564a8cb7"
    }
  }
}
